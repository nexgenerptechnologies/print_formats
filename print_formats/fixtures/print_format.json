        "html": "{% import "pro_print_formats/templates/print_formats/pro_base.html" as base %}\n{% call base.render_pro_format(doc, "SALES ORDER") %}\n<div style="display: flex; justify-content: space-between; margin-bottom: 20px; font-size: 9pt;">\n    <div style="width: 48%;">\n        <table style="width: 100%;">\n            <tr><td><strong>Doc No:</strong></td><td>{{ doc.name }}</td></tr>\n            <tr><td><strong>Date:</strong></td><td>{{ doc.get_formatted("posting_date") or doc.get_formatted("transaction_date") }}</td></tr>\n            <tr><td><strong>Transport:</strong></td><td>{{ doc.transporter_name or "N/A" }}</td></tr>\n            <tr><td><strong>Vehicle No:</strong></td><td>{{ doc.vehicle_no or "N/A" }}</td></tr>\n        </table>\n    </div>\n    <div style="width: 48%;">\n        <table style="width: 100%;">\n            <tr><td><strong>GR/RR No:</strong></td><td>{{ doc.lr_no or "N/A" }}</td></tr>\n            <tr><td><strong>E-Way Bill:</strong></td><td>{{ doc.ewaybill or "N/A" }}</td></tr>\n            <tr><td><strong>PO No:</strong></td><td>{{ doc.po_no or "N/A" }}</td></tr>\n            <tr><td><strong>Terms:</strong></td><td>{{ doc.payment_terms_template or "N/A" }}</td></tr>\n        </table>\n    </div>\n</div>\n<div style="display: flex; justify-content: space-between; margin-bottom: 20px;">\n    <div style="width: 48%; padding: 10px; background-color: #f9f9f9; border-radius: 4px;">\n        <strong>Billed To:</strong><br>\n        {{ doc.customer_name or doc.supplier_name }}<br>\n        {{ doc.address_display or "" }}<br>\n        {% if doc.company_gstin %}<strong>GSTIN:</strong> {{ doc.company_gstin }}{% endif %}\n    </div>\n    <div style="width: 48%; padding: 10px; background-color: #f9f9f9; border-radius: 4px;">\n        <strong>Shipped To:</strong><br>\n        {{ doc.shipping_address_name or (doc.customer_name or doc.supplier_name) }}<br>\n        {{ doc.shipping_address_display or doc.address_display or "" }}\n    </div>\n</div>\n<table style="width: 100%; border-collapse: collapse; margin-bottom: 20px; font-size: 9pt;">\n    <thead>\n        <tr style="background-color: #f1f1f1; border-bottom: 2px solid #ddd;">\n            <th style="padding: 8px; text-align: left;">Sr No</th>\n            <th style="padding: 8px; text-align: left;">Item Name & Description</th>\n            <th style="padding: 8px; text-align: right;">Qty</th>\n            <th style="padding: 8px; text-align: right;">Rate</th>\n            <th style="padding: 8px; text-align: right;">Amount</th>\n        </tr>\n    </thead>\n    <tbody>\n        {% for item in doc.items %}\n        <tr style="border-bottom: 1px solid #eee;">\n            <td style="padding: 8px;">{{ loop.index }}</td>\n            <td style="padding: 8px;"><strong>{{ item.item_name }}</strong><br><span style="font-size: 8pt; color: #666;">{{ item.description }}</span></td>\n            <td style="padding: 8px; text-align: right;">{{ item.qty }} {{ item.uom }}</td>\n            <td style="padding: 8px; text-align: right;">{{ item.get_formatted("rate") }}</td>\n            <td style="padding: 8px; text-align: right;">{{ item.get_formatted("amount") }}</td>\n        </tr>\n        {% endfor %}\n    </tbody>\n</table>\n<div style="display: flex; justify-content: flex-end; margin-bottom: 20px;">\n    <table style="width: 40%; font-size: 9pt;">\n        <tr><td style="padding: 4px;"><strong>Net Total:</strong></td><td style="padding: 4px; text-align: right;">{{ doc.get_formatted("total") or doc.get_formatted("net_total") }}</td></tr>\n        {% for tax in doc.taxes %}\n        <tr><td style="padding: 4px;">{{ tax.description }}:</td><td style="padding: 4px; text-align: right;">{{ tax.get_formatted("tax_amount") }}</td></tr>\n        {% endfor %}\n        <tr style="border-top: 1px solid #ddd;"><td style="padding: 4px;"><strong>Grand Total:</strong></td><td style="padding: 4px; text-align: right;"><strong>{{ doc.get_formatted("grand_total") }}</strong></td></tr>\n    </table>\n</div>\n<div style="font-size: 9pt; margin-bottom: 20px;">\n    <strong>Amount in Words:</strong> {{ doc.in_words }}\n</div>\n{% endcall %}"
